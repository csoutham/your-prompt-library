{
	"name": "prompt-store",
	"version": "0.7.0",
	"description": "Your prompt library is a local-first macOS prompt manager built with Electrobun, Bun, and React",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build",
		"build:stable": "vite build && electrobun build --env=stable",
		"build:testflight": "ELECTROBUN_TARGET=testflight vite build && ELECTROBUN_TARGET=testflight electrobun build --env=stable",
		"package:testflight": "./scripts/package-testflight.sh",
		"build:canary": "vite build && electrobun build --env=canary",
		"test": "bun test"
	},
	"dependencies": {
		"@phosphor-icons/react": "^2.1.10",
		"electrobun": "1.15.1",
		"gray-matter": "^4.0.3",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
